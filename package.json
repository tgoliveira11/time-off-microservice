{
  "name": "time-off-microservice",
  "version": "1.0.0",
  "description": "ExampleHR Time-Off Microservice - NestJS REST API with SQLite and HCM integration",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:sqlite": "cross-env PERSISTENCE_MODE=sqlite nest start --watch",
    "start:dev:memory": "cross-env PERSISTENCE_MODE=memory nest start --watch",
    "start:offline": "cross-env PERSISTENCE_MODE=memory SEED_MEMORY_DATA=true nest start",
    "start:prod": "node dist/main",
    "test": "jest --runInBand",
    "test:memory": "cross-env PERSISTENCE_MODE=memory jest --runInBand --testPathPattern=memory",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern=test/integration",
    "test:e2e": "jest --testPathPattern=test/e2e --runInBand",
    "test:contract": "jest --testPathPattern=test/contract",
    "verify:offline": "npm run build && npm run test:memory",
    "verify:sqlite": "npm run build && npm test && npm run test:cov"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "test/.*\\.(spec|e2e-spec|contract-spec)\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/domain/**/*.ts",
      "src/modules/balances/**/*.ts",
      "src/modules/system/**/*.ts",
      "src/modules/time-off-requests/**/*.ts",
      "src/modules/hcm/**/*.ts",
      "src/common/**/*.service.ts",
      "src/common/observability/**/*.ts",
      "src/database/repositories/**/*.ts",
      "src/database/memory/**/*.ts",
      "src/database/persistence-info.service.ts",
      "!src/database/persistence-mode.ts",
      "!src/**/*.module.ts",
      "!src/main.ts",
      "!src/modules/mock-hcm/**"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 85,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
